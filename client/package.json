{
  "name": "nexo-app",
  "version": "9.0.0",
  "description": "NEXO v9.0 - Mensajería P2P ultra-rápida, privada y viral",
  "private": true,
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "generate-assets": "bash scripts/copy-icons.sh",
    "sync": "cap sync",
    "android": "cap run android",
    "android:build": "npm run build && npm run generate-assets && cap sync android && cd android && ./gradlew assembleDebug",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "rimraf": "^5.0.5",
    "terser": "^5.30.0",
    "vite": "^5.2.0"
  },
  "browserslist": [
    "Android >= 8",
    "ChromeAndroid >= 80"
  ],
  "keywords": [
    "p2p",
    "messaging",
    "webrtc",
    "ble",
    "encryption",
    "privacy",
    "capacitor",
    "mobile"
  ],
  "author": "NEXO Team",
  "license": "MIT"
}
