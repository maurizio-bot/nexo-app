{
  "name": "nexo-v9",
  "version": "9.0.0",
  "description": "Arquitectura Lateral — Stream + Vault",
  "main": "src/main.js",
  "scripts": {
    "build": "npm run build:web && npm run build:android",
    "build:web": "webpack --mode=production",
    "build:android": "capacitor sync android && cd android && ./gradlew assembleRelease",
    "dev": "webpack serve --mode=development",
    "sync": "capacitor sync",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^3.1.1",
    "@capacitor/android": "^5.7.0",
    "@capacitor/app": "^5.0.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/geolocation": "^5.0.0",
    "@capacitor-community/bluetooth-le": "^3.1.4",
    "@capacitor/app": "^5.0.0",
    "@capacitor/haptics": "^5.0.0",
    "comlink": "^4.4.1",
    "idb": "^8.0.0",
    "socket.io-client": "^4.7.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@types/web-bluetooth": "^0.0.16",
    "copy-webpack-plugin": "^12.0.0",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
