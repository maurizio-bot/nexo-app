{
  "name": "nexo-v9",
  "version": "9.0.0",
  "description": "NEXO v9.0 - Mensajería P2P ultra-rápida con BLE Mesh",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "build:android": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "build:android:release": "npm run build && cap sync android && cd android && ./gradlew assembleRelease",
    "test": "vitest",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^3.1.1",
    "@capacitor/android": "^5.7.0",
    "@capacitor/app": "^5.0.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/device": "^5.0.0",
    "@capacitor/keyboard": "^5.0.0",
    "@capacitor/preferences": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "buffer": "^6.0.3",
    "crypto-js": "^4.2.0",
    "qrcode": "^1.5.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "vite-plugin-pwa": "^0.17.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "eslint": "^8.57.0",
    "terser": "^5.29.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0"
  },
  "browserslist": [
    "last 2 Android versions",
    "last 2 Chrome versions",
    "last 2 Safari versions",
    "iOS >= 14"
