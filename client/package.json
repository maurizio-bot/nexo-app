    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "p2p",
    "messaging",
    "ble",
    "mesh",
    "capacitor",
    "webrtc",
    "encrypted"
  ],
  "author": "NEXO Team",
  "license": "MIT",
  "capacitor": {
    "android": {
      "src": "android"
    }
  }
